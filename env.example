# Supabase Configuration
# Get these values from your Supabase project dashboard
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: Supabase Service Role Key (for admin operations)
# Only use this in secure server-side environments
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
REACT_APP_APP_NAME=Remix Music
REACT_APP_APP_VERSION=1.0.0
REACT_APP_APP_DESCRIPTION=A modern music social media app with chat, recommendations, and storefront

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=10485760 # 10MB in bytes
REACT_APP_ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/ogg,audio/mp4
REACT_APP_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Feature Flags
REACT_APP_ENABLE_REAL_TIME=true
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_ENABLE_COMMENTS=true
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_STORE=true
REACT_APP_ENABLE_UPLOAD=true

# Copyright automation (optional)
# For /api/check-copyright to honor is_verified_artist (verified artists), set:
# SUPABASE_URL=your_supabase_url  (same as VITE_SUPABASE_URL without VITE_ prefix, in Vercel env)
# SUPABASE_SERVICE_ROLE_KEY=...   (server-side only; do not expose in client)
# Comma-separated list of blocked file hashes (SHA-256) as JSON array, e.g. ["abc123..."]
# COPYRIGHT_BLOCKED_HASHES=[]
# ACRCloud (optional – for acoustic fingerprinting; get keys at console.acrcloud.com)
# ACR_CLOUD_HOST=
# ACR_CLOUD_ACCESS_KEY=
# ACR_CLOUD_ACCESS_SECRET=